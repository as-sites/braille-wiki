{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@braille-wiki/db": ["./packages/db/src"],
      "@braille-wiki/db/*": ["./packages/db/src/*"],
      "@braille-wiki/shared": ["./packages/shared/src"],
      "@braille-wiki/shared/*": ["./packages/shared/src/*"],
      "@braille-wiki/editor-schema": ["./packages/editor-schema/src"],
      "@braille-wiki/editor-schema/*": ["./packages/editor-schema/src/*"]
    }
  }
}
