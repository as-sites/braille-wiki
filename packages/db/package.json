{
  "name": "@braille-docs/db",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.cts,.mts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@neondatabase/serverless": "latest",
    "drizzle-orm": "latest",
    "drizzle-zod": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "dotenv": "latest",
    "drizzle-kit": "latest"
  }
}
