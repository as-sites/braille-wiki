{
  "name": "@braille-docs/admin",
  "private": true,
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "generate:api": "node -e \"const fs=require('node:fs');const src='../../packages/shared/openapi.yaml';const tmp='./openapi.compat.yaml';const text=fs.readFileSync(src,'utf8').replace(/^openapi:\\s*3\\.2\\.0/m,'openapi: 3.1.0');fs.writeFileSync(tmp,text);\" && openapi-typescript openapi.compat.yaml -o src/api/generated/api.ts && node -e \"require('node:fs').unlinkSync('openapi.compat.yaml')\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.cts,.mts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@braille-docs/editor-schema": "workspace:*",
    "@braille-docs/shared": "workspace:*",
    "@tiptap/core": "3.22.2",
    "@tiptap/extension-code-block": "3.22.2",
    "@tiptap/extension-image": "3.22.2",
    "@tiptap/extension-link": "3.22.2",
    "@tiptap/extension-placeholder": "3.22.2",
    "@tiptap/extension-text-align": "3.22.2",
    "@tiptap/extension-underline": "3.22.2",
    "@tiptap/pm": "3.22.2",
    "@tiptap/react": "3.22.2",
    "@tiptap/starter-kit": "3.22.2",
    "better-auth": "^1.5.6",
    "openapi-fetch": "^0.17.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "^7.5.2"
  },
  "devDependencies": {
    "@tiptap/cli": "3.19.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "openapi-typescript": "^7.9.1",
    "sass-embedded": "^1.93.2",
    "vite": "^8.0.3"
  }
}
