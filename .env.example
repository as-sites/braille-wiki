# Domain / routing
DOMAIN=example.com

# Neon Postgres connection string
DATABASE_URL=postgresql://user:pass@host/db

# better-auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://api.example.com

# Initial admin user created on first startup (seed script)
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=

# Internal service auth + routing
INTERNAL_SECRET=
ASTRO_INTERNAL_URL=http://web:4321

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Generic S3-compatible storage (optional, e.g. Railway Buckets)
# If set, these take precedence over R2_* values in the API service.
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_PUBLIC_URL=
S3_FORCE_PATH_STYLE=false

# Public URLs
PUBLIC_API_URL=https://api.example.com
VITE_API_URL=https://api.example.com
ADMIN_ORIGIN=https://admin.example.com

# Traefik notes:
# - ACME contact email is configured in traefik/traefik.yml
# - Dashboard basic auth default in traefik/dynamic/routes.yml is admin/admin (demo only)

